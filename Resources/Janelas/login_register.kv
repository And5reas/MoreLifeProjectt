WindowManager:
    JanelaLogin:
    JanelaRegistrar:

<TextInput>
    canvas.before:
        Color:
            rgba: (0, 0, 0, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, 1)

<Button>
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, 1)


<Label>
    canvas.before:
        Color:
            rgba: (1,1,1,1)
        Rectangle:
            size: self.size
            pos: self.pos
    color: (0,0,0,1)

<JanelaLogin>:
    name: "login_screen"
    BoxLayout:
        size: root.width, root.height
        orientation: "vertical"

        padding: 10
        spacing: 5

        canvas.before:
            Color:
                rgba: (1,1,1,1)
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Login"
            font_size: "15pt"

            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100

        Image:
            source: "Resources/Imgs/Logo.png"

        GridLayout:
            cols: 2
            spacing: 8

            Label:
                text: "Email:"
                font_size: "11pt"
                pos_hint: {'center_y': 0.5}
                size_hint: (None, None)
                width: 38
                height: 30
            TextInput:
                id: email_input
                multiline: False
                font_size: "11pt"
                pos_hint: {'center_y': 0.5}
                size_hint: (None, None)
                width: 326
                height: 30
                do_wrap: False
                write_tab: False

            Label:
                text: "Senha:"
                font_size: "11pt"
                pos_hint: {'center_y': 0.5}
                size_hint: (None, None)
                width: 38
                height: 30
            TextInput:
                id: password_input
                password: True
                multiline: False
                font_size: "11pt"
                pos_hint: {'center_y': 0.5}
                size_hint: (None, None)
                width: 326
                height: 30
                do_wrap: False
                write_tab: False

        Label:
            text: ""
            id: error_login
            font_size: "10pt"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100
            color: (1,0,0,1)


        Button:
            text: "Login"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 90
            on_press: root.btn_login()

        Button:
            text: "Registrar-se"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 90
            on_release:
                app.root.current = "register_screen"
                root.manager.transition.direction = "up"

<JanelaRegistrar>:
    name: "register_screen"
    BoxLayout:
        size: root.width, root.height
        orientation: "vertical"

        padding: 10
        spacing: 10

        canvas.before:
            Color:
                rgba: (1,1,1,1)
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Registrar-se"
            font_size: "15pt"

            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100

        Image:
            source: "Resources/Imgs/Logo.png"


        GridLayout:
            cols: 2
            spacing: 8

            Label:
                text: "Nome:"
                font_size: "11pt"
                pos_hint: {'center_x': 0.5}
                width: 38
                height: 30
            TextInput:
                id: user_name
                multiline: False
                font_size: "11pt"
                pos_hint: {'center_y': 0.5}
                size_hint: (None, None)
                width: 260
                height: 30
                do_wrap: False
                write_tab: False

            Label:
                text: "Email:"
                font_size: "11pt"
                pos_hint: {'center_x': 0.5}
                width: 38
                height: 30
            TextInput:
                id: email_register
                multiline: False
                font_size: "11pt"
                pos_hint: {'center_y': 0.5}
                size_hint: (None, None)
                width: 260
                height: 30
                do_wrap: False
                write_tab: False

            Label:
                text: "Senha:"
                font_size: "11pt"
                pos_hint: {'center_x': 0.5}
                width: 38
                height: 30
            TextInput:
                id: password_register
                password: True
                multiline: False
                font_size: "11pt"
                pos_hint: {'center_x': 0.5}
                size_hint: (None, None)
                width: 260
                height: 30
                do_wrap: False
                write_tab: False

            Label:
                text: "Confirmar senha:"
                font_size: "11pt"
                pos_hint: {'center_x': 0.5}
                size_hint: (None, None)
                width: 120
                height: 30
            TextInput:
                id: password_confirm_register
                password: True
                multiline: False
                font_size: "11pt"
                pos_hint: {'center_x': 0.5}
                size_hint: (None, None)
                width: 260
                height: 30
                do_wrap: False
                write_tab: False

        BoxLayout:
            cols: 2
            spacing: 8
            size_hint: (None, None)
            size: 70, 70
            pos_hint: {"center_x": .5}


            Button:
                text: "Registrar conta"
                pos_hint: {'center_x': .5}
                size_hint: (None, None)
                height: 25
                width: 120

            Button:
                text: "Voltar"
                pos_hint: {'center_x': 0.5}
                size_hint: (None, None)
                height: 25
                width: 90
                on_release:
                    app.root.current = "login_screen"
                    root.manager.transition.direction = "down"
