#: import NoTransition kivy.uix.screenmanager.NoTransition

WindowManager:
    JanelaLogin:
    JanelaMain:
    JanelaReport:
    JanelaConfig:

<TextInput>:
    canvas.before:
        Color:
            rgba: (0, 0, 0, 1)
        Line:
            width: 1.1
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Button>:
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Spinner>:
    canvas.before:
        Color:
            rgba: (.6, .6, .6, 1)
        Rectangle:
            size: self.size
            pos: self.pos
    background_normal: ''
    background_color: (.6 ,.6 ,.6 ,1)

<ButtonSemStyle@Button>:
    canvas.before:
        Color:
            rgba: (1, 1, 1, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Label>:
    canvas.before:
        Color:
            rgba: (1,1,1,.5)
        Rectangle:
            size: self.size
            pos: self.pos
    color: (0,0,0,1)

<CheckBox>:
    canvas.before:
        Color:
            rgba: (0,0,0,1)
        Line:
            width: 1
            rectangle: self.x, self.y, self.width, self.height

<JanelaLogin>:
    name: "login_screen"
    BoxLayout:
        size: root.width, root.height
        orientation: "vertical"

        padding: 10
        spacing: 5

        Label:
            text: "Login"
            font_size: "15pt"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100

        Image:
            source: "Resources/Imgs/Logo_pequeno.png"

        GridLayout:
            cols: 2
            spacing: 8

            Label:
                text: "Email:"
                font_size: "11pt"
                size_hint: (None, None)
                width: 38
                height: 30
            TextInput:
                id: email_input
                multiline: False
                font_size: "11pt"
                size_hint: (None, None)
                width: 326
                height: 30
                do_wrap: False
                write_tab: False
                on_text: root.validate_color()

            Label:
                text: "Senha:"
                font_size: "11pt"
                size_hint: (None, None)
                width: 38
                height: 30
            TextInput:
                id: password_input
                password: True
                multiline: False
                font_size: "11pt"
                size_hint: (None, None)
                width: 326
                height: 30
                do_wrap: False
                write_tab: False
                on_text: root.validate_color()

            Label:
                # Label para pular uma coluna do grid

            BoxLayout
                orientation: "horizontal"
                spacing: 10

                Label:
                    text: "[ref=Lembrar senha e email?]Lembrar senha e email?[/ref]"
                    pos_hint: {'center_y': 0.5}
                    markup: True
                    size_hint: (None, None)
                    width: 155
                    height: 40
                    on_ref_press: root.keep_login(check_keep_login.active)

                CheckBox:
                    id: check_keep_login
                    pos_hint: {'center_y': 0.5}
                    size_hint: (None, None)
                    width: 15
                    height: 15

                
                FloatLayout:
                    ButtonSemStyle:
                        size_hint: (None, None)
                        size: 30, 30
                        y: 100
                        x: 260
                        pos_hint: {"right":0.9}
                        on_press: root.remove_password_mask()
                        background_disabled_normal: "False"
                        Image:
                            id: eye_password_mask
                            y: self.parent.y
                            x: self.parent.x
                            size: 30, 30
                            source: "Resources\Imgs\zoio_fechado.png"

        Label:
            text: ""
            id: error_login
            font_size: "10pt"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100
            color: (1,0,0,1)


        Button:
            text: "Login"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 90
            on_release: if root.btn_login(): app.root.current = "main_screen"

        Button:
            text: "Registrar-se"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 90

<GridPrincipal@GridLayout>
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height

<GridReport@GridLayout>
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height

<GridConfig@GridLayout>
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height


<JanelaMain>:
    name: "main_screen"
    GridLayout:
        size: root.width, root.height
        cols: 2

        padding: 40
        spacing: 40

        BoxLayout:
            orientation: "vertical"

            spacing: 40

            Image:
                source: "Resources/Imgs/Logo.png"

            BoxLayout:
                size: (83, 210)
                orientation: "vertical"

                Button:
                    text: "Principal"
                    background_color: (51/255, 184/255, 18/255, .5)
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "main_screen"

                Button:
                    text: "Relatórios"
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "report_screen"

                Button:
                    text: "Configurações"
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "config_screen"

                BoxLayout:
                    orientation: "horizontal"

                    Button:
                        text: "Conta"

                    Button:
                        text: "Sair"
                        on_press: app.root.current = "login_screen"

        GridPrincipal:
            cols: 4
            rows: 4

            Label:
                text: "Principal"

<JanelaReport>:
    name: "report_screen"
    GridLayout:
        size: root.width, root.height
        cols: 2

        padding: 40
        spacing: 40

        BoxLayout:
            orientation: "vertical"

            spacing: 40

            Image:
                source: "Resources/Imgs/Logo.png"

            BoxLayout:
                size: (83, 210)
                orientation: "vertical"

                Button:
                    text: "Principal"
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "main_screen"

                Button:
                    text: "Relatórios"
                    background_color: (51/255, 184/255, 18/255, .5)
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "report_screen"

                Button:
                    text: "Configurações"
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "config_screen"

                BoxLayout:
                    orientation: "horizontal"

                    Button:
                        text: "Conta"

                    Button:
                        text: "Sair"
                        on_press: app.root.current = "login_screen"

        GridReport:
            cols: 4
            rows: 4

            Label:
                text: "Relatórios"

<JanelaConfig>:
    name: "config_screen"
    GridLayout:
        size: root.width, root.height
        cols: 2

        padding: 40
        spacing: 40

        BoxLayout:
            orientation: "vertical"

            spacing: 40

            Image:
                source: "Resources/Imgs/Logo.png"

            BoxLayout:
                size: (83, 210)
                orientation: "vertical"

                Button:
                    text: "Principal"
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "main_screen"

                Button:
                    text: "Relatórios"
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "report_screen"

                Button:
                    text: "Configurações"
                    background_color: (51/255, 184/255, 18/255, .5)
                    on_release:
                        root.manager.transition = NoTransition()
                        app.root.current = "config_screen"

                BoxLayout:
                    orientation: "horizontal"

                    Button:
                        text: "Conta"

                    Button:
                        text: "Sair"
                        on_press: app.root.current = "login_screen"

        GridConfig:
            cols: 1

            spacing: 5
            padding: 10

            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: 30

                Spinner:
                    id: resolucao_config
                    text: "Resolução da tela"
                    pos_hint: {"center_x": .5, "center_y": .5}
                    size_hint_y: None
                    height: 25
                    on_text: root.change_resolution(self.text)

            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: 30

                Spinner:
                    id: spinner_tema
                    text: "Temas"
                    values: ["Dark", "Light", "Dark Blue"]
                    pos_hint: {"center_x": .5, "center_y": .5}
                    size_hint_y: None
                    height: 25
                    on_text: root.change_tema(self.text)
            
            
                

