#: import NoTransition kivy.uix.screenmanager.NoTransition

WindowManager:
    JanelaLogin:
    JanelaMain:
    JanelaAlertas:
    JanelaReport:
    JanelaConfig:

<TextInput>:
    canvas.before:
        Color:
            rgba: (0, 0, 0, 1)
        Line:
            width: 1.1
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Button>:
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Spinner>:
    canvas.before:
        Color:
            rgba: (.6, .6, .6, 1)
        Rectangle:
            size: self.size
            pos: self.pos
    background_normal: ''
    background_color: (.6 ,.6 ,.6 ,1)

<ButtonSemStyle@Button>:
    canvas.before:
        Color:
            rgba: (1, 1, 1, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Label>:
    color: (0,0,0,1)

<LblLogin@Label>:
    canvas.before:
        Color:
            rgba: (1,1,1,.5)
        Rectangle:
            size: self.size
            pos: self.pos
    color: (0,0,0,1)

<CheckBox>:
    canvas.before:
        Color:
            rgba: (0,0,0,1)
        Line:
            width: 1
            rectangle: self.x, self.y, self.width, self.height

<JanelaLogin>:
    name: "login_screen"
    BoxLayout:
        size: root.width, root.height
        orientation: "vertical"

        padding: 10
        spacing: 5

        LblLogin:
            text: "Login"
            font_size: "15pt"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100

        Image:
            source: "Resources/Imgs/Logo_pequeno.png"

        GridLayout:
            cols: 2
            spacing: 8

            LblLogin:
                text: "Email:"
                font_size: "11pt"
                size_hint: (None, None)
                width: 38
                height: 30
            TextInput:
                id: email_input
                multiline: False
                font_size: "11pt"
                size_hint: (None, None)
                width: 326
                height: 30
                do_wrap: False
                write_tab: False
                on_text: root.validate_color()

            LblLogin:
                text: "Senha:"
                font_size: "11pt"
                size_hint: (None, None)
                width: 38
                height: 30
            TextInput:
                id: password_input
                password: True
                multiline: False
                font_size: "11pt"
                size_hint: (None, None)
                width: 326
                height: 30
                do_wrap: False
                write_tab: False
                on_text: root.validate_color()

            LblLogin:
                # Label para pular uma coluna do grid

            BoxLayout
                orientation: "horizontal"
                spacing: 10

                LblLogin:
                    text: "[ref=Lembrar senha e email?]Lembrar senha e email?[/ref]"
                    pos_hint: {'center_y': 0.5}
                    markup: True
                    size_hint: (None, None)
                    width: 155
                    height: 40
                    on_ref_press: root.keep_login(check_keep_login.active)

                CheckBox:
                    id: check_keep_login
                    pos_hint: {'center_y': 0.5}
                    size_hint: (None, None)
                    width: 15
                    height: 15

                
                FloatLayout:
                    ButtonSemStyle:
                        size_hint: (None, None)
                        size: 30, 30
                        y: 100
                        x: 260
                        pos_hint: {"right":0.9}
                        on_press: root.remove_password_mask()
                        background_disabled_normal: "False"
                        Image:
                            id: eye_password_mask
                            y: self.parent.y
                            x: self.parent.x
                            size: 30, 30
                            source: "Resources\Imgs\zoio_fechado.png"

        LblLogin:
            text: ""
            id: error_login
            font_size: "10pt"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 100
            color: (1,0,0,1)


        Button:
            text: "Login"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 90
            on_release: if root.btn_login(): app.root.current = "main_screen"

        Button:
            text: "Registrar-se"
            pos_hint: {'center_x': 0.5}
            size_hint: (None, None)
            height: 25
            width: 90


<JanelaMain>:
    name: "main_screen"
    GridLayout:
        size: root.width, root.height
        cols: 2

        padding: 40
        spacing: 40

        BoxLayout:
            orientation: "vertical"
            size_hint: None, 1
            size: 240, 0

            canvas:
                Color:
                    rgba: 0.3, 0.2, 0.3, .5
                Rectangle:
                    pos: self.x - 40, self.y - 40
                    size: self.width + 60, self.height + 80

            spacing: 40

            Image:
                source: "Resources/Imgs/Logo_pequeno.png"
                size_hint: 1, .35
                
            BoxLayout:
                orientation: "vertical"

                
                BoxLayout:
                    orientation: "vertical"
                    
                    Button:
                        text: "Principal"
                        background_color: (51/255, 184/255, 18/255, .5)
                        on_release:
                            root.manager.transition = NoTransition()
                            app.root.current = "main_screen"

                    Button:
                        text: "Alertas"
                        on_release:
                            root.manager.transition = NoTransition()
                            app.root.current = "alert_screen"

                    Button:
                        text: "Relatórios"
                        on_release:
                            root.manager.transition = NoTransition()
                            app.root.current = "report_screen"

                BoxLayout:
                    orientation: "vertical"
                    size_hint: 1, None
                    size: 0, 130

                    Button:
                        text: "Configurações"
                        text_size: self.width - 130/3 - 20, self.height - 130/3
                        on_release:
                            root.manager.transition = NoTransition()
                            app.root.current = "config_screen"

                    Button:
                        text: "Conta"
                        text_size: self.width - 130/3 - 20, self.height - 130/3

                    Button:
                        text: "Sair"
                        text_size: self.width - 130/3 - 20, self.height - 130/3
                        on_press: app.root.current = "login_screen"

        GridLayout:
            cols: 1

            BoxLayout:
                orientation: "horizontal"
                size_hint: 1, .1

                Label:
                    text: "Deseja iniciar o MoreLife?"
                    color: (1,1,1,1)

                ToggleButton:
                    id: tgb_start_read_beats
                    text: "Principal"
                    on_press: root.start_read_beats()
                    
            BoxLayout:
                orientation: "horizontal"
                size_hint: 1, .1

                Label:
                    text: "Batimentos por minuto:"
                    color: (1,1,1,1)

                Label:
                    id: Batimentos
                    text: 'Printar'
                    color: (1,1,1,1)
            Label:
                text: "Coisas"
                color: (1,1,1,1)

<JanelaAlertas>:
    name: "alert_screen"
    GridLayout:
        size: root.width, root.height
        cols: 2

        padding: 40
        spacing: 40

        BoxLayout:
            orientation: "vertical"
