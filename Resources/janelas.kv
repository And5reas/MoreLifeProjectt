#: import NoTransition kivy.uix.screenmanager.NoTransition
#: include Resources/login.kv
#: include Resources/principal.kv
#: include Resources/alarme.kv
#: include Resources/report.kv
#: include Resources/config.kv

WindowManager:
    JanelaLogin:
    JanelaMain:
    JanelaAlertas:
    JanelaReport:
    JanelaConfig:

<TextInput>:
    canvas.before:
        Color:
            rgba: (0, 0, 0, 1)
        Line:
            width: 1.1
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Button>:
    canvas.before:
        Color:
            rgba: (.5, .5, .5, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Spinner>:
    canvas.before:
        Color:
            rgba: (.6, .6, .6, 1)
        Rectangle:
            size: self.size
            pos: self.pos
    background_normal: ''
    background_color: (.6 ,.6 ,.6 ,1)

<ButtonSemStyle@Button>:
    canvas.before:
        Color:
            rgba: (1, 1, 1, 1)
        Line:
            width: 2
            rectangle: self.x, self.y, self.width, self.height
    background_normal: ''
    background_color: (1, 1, 1, .5)

<Label>:
    color: (0,0,0,1)

<LblLogin@Label>:
    canvas.before:
        Color:
            rgba: (1,1,1,.5)
        Rectangle:
            size: self.size
            pos: self.pos
    color: (0,0,0,1)

<CheckBox>:
    canvas.before:
        Color:
            rgba: (0,0,0,1)
        Line:
            width: 1
            rectangle: self.x, self.y, self.width, self.height
            
            
                

