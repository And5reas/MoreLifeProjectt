#:import utils kivy.utils
<MyGridLayout>

    name: name
    pizza: pizza
    color: color

    GridLayout:
        cols: 1
        size: root.width, root.height

        GridLayout:
            cols: 2

            Label:
                text: "Name:"
            TextInput:
                id: name
                multiline: False
                background_normal: ''
                background_color: (173/255,14/255,165/255,0.6)

            Label:
                text: "Favorite pizza:"
            TextInput:
                id: pizza
                multiline: False

            Label:
                text: "Favorite color:"
            TextInput:
                id: color
                multiline: False

        Button:
            text: "Submit"
            font_size: 50
            on_press: root.press()
            # RGB - A
            # Make color normal '-'
            background_normal: ''
            # background_color: (173/255,14/255,165/255,1)
            background_color: utils.get_color_from_hex('#f2de05')