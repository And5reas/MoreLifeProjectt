#:import utils kivy.utils
<Button>
    background_normal: ''
    background_color: utils.get_color_from_hex("#2ea8ff")

<TextInput>
    background_color: utils.get_color_from_hex("#0cf232")

<Label>
    font_size: 32


<MyLayout>
    BoxLayout:
        orientation: "vertical"
        size: root.width, root.height
        padding:10
        spacing:10

        Label:
            text: "Name"
        TextInput:
            multiline: False

        Label:
            text: "Favorite Pizza"
        TextInput:
            multiline: False

        Button:
            text: "Submit"

        Button:
            text: "Clear"
            font_size: 40
            background_color: utils.get_color_from_hex("#ff0a64")
