#:import utils kivy.utils
<Button>
    background_normal: ''
    background_color: utils.get_color_from_hex("#2ea8ff")

<TextInput>
    background_color: utils.get_color_from_hex("#0cf232")

<Label>
    font_size: 32

<MyLayout>
    # change window bg color
    canvas.before:
        Color:
            rgba: (150/255,150/255,150/255,0.5)
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        size: root.width, root.height
        padding:10
        spacing:10

        Label:
            text: "Name"
            background_color: (1,0,0,1)
            canvas.before:
                Color:
                    rgba: self.background_color
                Rectangle:
                    size: self.size
                    pos: self.pos
            # text properties
            color: (0,0,1,1)
            outline_color: (1,1,1)
            outline_width: 2

        TextInput:
            multiline: False


        Button:
            text: "Clear"
            font_size: 40
            background_color: utils.get_color_from_hex("#ff0a64")
